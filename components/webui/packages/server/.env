# Using NODE_ENV with non-"production" values is an antipattern due to inconsistent behavior
# in dependencies across environments.
# Reference: https://nodejs.org/en/learn/getting-started/nodejs-the-difference-between-development-and-production
NODE_ENV=production

# Network
HOST=localhost
PORT=3000

# Database
CLP_DB_USER=clp-user
CLP_DB_PASS=GGc_V-dcek0

# Database (MySQL driver for Hono datasource routes)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=clp-user
MYSQL_PASSWORD=GGc_V-dcek0
MYSQL_DATABASE=clp-db

#Presto
PRESTO_CATALOG=clp
PRESTO_SCHEMA=default

# Security
RATE_LIMIT=1000

