{
  "name": "@webui/server",
  "version": "0.1.0",
  "private": true,
  "description": "CLP Web UI Server - Hono + Fastify",
  "main": "src/main.ts",
  "exports": {
    "./hono-app": {
      "types": "./src/hono-app.ts",
      "import": "./src/hono-app.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w --preserveWatchOutput",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/src/app.js",
    "dev": "pnpm run build && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:build:watch\" \"pnpm:dev:start\"",
    "start": "pnpm run build && fastify start -l info dist/src/app.js",
    "standalone": "pnpm run build && node --env-file=.env dist/src/main.js",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "author": "YScope Inc. <dev@yscope.com>",
  "license": "Apache-2.0",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@smithy/types": "^3.0.0",
    "@fastify/autoload": "^6.3.1",
    "@fastify/env": "^5.0.3",
    "@fastify/error": "^4.2.0",
    "@fastify/http-proxy": "^11.4.1",
    "@fastify/mongodb": "^9.0.2",
    "@fastify/mysql": "^5.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@hono/node-server": "catalog:",
    "@hono/typebox-validator": "catalog:",
    "@msgpack/msgpack": "^3.1.3",
    "@sinclair/typebox": "catalog:",
    "@webui/common": "workspace:*",
    "@webui/datasource": "workspace:*",
    "close-with-grace": "^2.4.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.1",
    "fastify-plugin": "^5.1.0",
    "hono": "catalog:",
    "mongodb": "^6.21.0",
    "mysql2": "^3.22.3",
    "nanoid": "^5.1.0",
    "pino-pretty": "^13.1.3",
    "presto-client": "^1.1.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/presto-client": "^1.0.2",
    "concurrently": "^9.2.1",
    "eslint-config-yscope": "1.1.2",
    "fastify-cli": "^7.4.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
