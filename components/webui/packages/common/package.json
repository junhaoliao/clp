{
  "name": "@webui/common",
  "version": "0.1.0",
  "exports": {
    "./dashboard/schemas": {
      "types": "./dist/dashboard/schemas.d.ts",
      "import": "./dist/dashboard/schemas.js"
    },
    "./dashboard/types": {
      "types": "./dist/dashboard/types.d.ts",
      "import": "./dist/dashboard/types.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w --preserveWatchOutput",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "YScope Inc. <dev@yscope.com>",
  "license": "Apache-2.0",
  "type": "module",
  "dependencies": {
    "@sinclair/typebox": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint-config-yscope": "1.1.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
