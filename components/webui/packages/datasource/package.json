{
  "name": "@webui/datasource",
  "version": "0.1.0",
  "private": true,
  "description": "CLP Dashboard Datasource abstractions and implementations",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./mysql": {
      "types": "./dist/mysql/index.d.ts",
      "import": "./dist/mysql/index.js"
    },
    "./clp": {
      "types": "./dist/clp/index.d.ts",
      "import": "./dist/clp/index.js"
    },
    "./infinity": {
      "types": "./dist/infinity/index.d.ts",
      "import": "./dist/infinity/index.js"
    },
    "./circuit-breaker": {
      "types": "./dist/circuit-breaker.d.ts",
      "import": "./dist/circuit-breaker.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w --preserveWatchOutput",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "author": "YScope Inc. <dev@yscope.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@sinclair/typebox": "catalog:",
    "@webui/common": "workspace:*",
    "dayjs": "catalog:"
  },
  "devDependencies": {
    "eslint-config-yscope": "1.1.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
