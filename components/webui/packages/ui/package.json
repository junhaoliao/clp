{
  "name": "@webui/ui",
  "version": "0.1.0",
  "private": true,
  "description": "CLP Dashboard shared UI components (panel chrome, grid)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w --preserveWatchOutput",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "YScope Inc. <dev@yscope.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@dnd-kit/collision": "catalog:",
    "@dnd-kit/dom": "catalog:",
    "@dnd-kit/helpers": "catalog:",
    "@dnd-kit/react": "catalog:",
    "@webui/common": "workspace:*",
    "@webui/datasource": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "eslint-config-yscope": "1.1.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
